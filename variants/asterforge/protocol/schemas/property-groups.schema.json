{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://asterforge.dev/schemas/property-groups.schema.json",
  "title": "PropertyResponse",
  "type": "object",
  "required": [
    "object_id",
    "groups"
  ],
  "properties": {
    "object_id": {
      "type": "string"
    },
    "groups": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "group_id",
          "title",
          "properties"
        ],
        "properties": {
          "group_id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "properties": {
            "type": "array",
            "items": {
              "$ref": "./property.schema.json"
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
